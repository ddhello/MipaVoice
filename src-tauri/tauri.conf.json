{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MipaVoice",
  "version": "0.1.0",
  "identifier": "com.mipavoice.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @mipavoice/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @mipavoice/web build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MipaVoice",
        "width": 1160,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

